{
  "name": "distilled-core",
  "version": "0.0.1",
  "files": [
    "lib",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./Category": {
      "types": "./lib/category.d.ts",
      "bun": "./src/category.ts",
      "default": "./lib/category.js"
    },
    "./Retry": {
      "types": "./lib/retry.d.ts",
      "bun": "./src/retry.ts",
      "default": "./lib/retry.js"
    },
    "./Sensitive": {
      "types": "./lib/sensitive.d.ts",
      "bun": "./src/sensitive.ts",
      "default": "./lib/sensitive.js"
    },
    "./Traits": {
      "types": "./lib/traits.d.ts",
      "bun": "./src/traits.ts",
      "default": "./lib/traits.js"
    },
    "./Pagination": {
      "types": "./lib/pagination.d.ts",
      "bun": "./src/pagination.ts",
      "default": "./lib/pagination.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {},
  "devDependencies": {
    "effect": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
